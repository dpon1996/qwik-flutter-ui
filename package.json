{
  "name": "qwik-flutter-ui",
  "version": "0.0.1",
  "description": "Flutter-inspired UI component library for Qwik.",
  "keywords": [
    "qwik",
    "qwik-ui",
    "flutter",
    "ui",
    "components",
    "library",
    "design-system"
  ],
  "license": "MIT",
  "author": {
    "name": "Dhanesh",
    "email": "dpon1996@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhaneshp/qwik-flutter-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dhaneshp/qwik-flutter-ui/issues"
  },
  "homepage": "https://github.com/dhaneshp/qwik-flutter-ui#readme",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "type": "module",
  "main": "./lib/index.qwik.mjs",
  "qwik": "./lib/index.qwik.mjs",
  "types": "./lib-types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib-types/index.d.ts",
      "import": "./lib/index.qwik.mjs",
      "require": "./lib/index.qwik.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "lib-types",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build.lib && npm run build.types",
    "build.lib": "vite build --mode lib",
    "build.types": "tsc -p tsconfig.lib.json",
    "build.playground": "qwik build",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "vitest run",
    "test.watch": "vitest",
    "preview": "qwik build preview && vite preview --open",
    "release": "np --no-tests",
    "start": "vite --open --mode ssr",
    "prepublishOnly": "npm run build",
    "qwik": "qwik"
  },
  "peerDependencies": {
    "@builder.io/qwik": ">=1.20.0"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.20.0",
    "@builder.io/qwik-city": "^1.20.0",
    "@eslint/js": "^9",
    "@types/node": "20.19.0",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.20.0",
    "globals": "16.4.0",
    "happy-dom": "^20.10.1",
    "np": "^10.0.0",
    "prettier": "3.6.2",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.1.8"
  }
}
