{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "lib-types",
    "rootDir": "src",
    "stripInternal": true
  },
  "include": ["src/index.ts", "src/lib/**/*", "src/components/app-shell/**/*", "src/components/app-bar/**/*", "src/components/drawer/**/*"],
  "exclude": [
    "src/routes",
    "src/entry.dev.tsx",
    "src/entry.preview.tsx",
    "src/entry.ssr.tsx",
    "src/root.tsx",
    "src/components/router-head",
    "src/global.css",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
